# Dart / Flutter
.dart_tool/
build/
*.g.dart.bak
.flutter-plugins-dependencies
.packages

# DevTools extension bundles — generated by tool/build_devtools_extension.sh,
# rebuilt on demand (mirrors lenny). The config.yaml is tracked; build/ is not.
packages/*/extension/devtools/build/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# .beads/ exclusions are owned by bd's own .beads/.gitignore (kept current with
# `bd doctor`). Do NOT blanket-ignore `.beads/*` with negations here: bd warns
# that negation patterns override the fork protection in .git/info/exclude, and
# the blanket hides files bd expects tracked (config.yaml carries sync.remote,
# so a fresh clone can't bootstrap without it).
#
# Per-machine files bd's template doesn't cover yet:
.beads/hooks.log
.beads/routes.jsonl
.beads/formulas/

# the_grid live-arm worktrees (the tree engine cuts per-bead worktrees here when
# THIS checkout is the substation root: .grid/worktrees/<substation>/<bead>).
# Never tracked — they are throwaway working copies of this repo.
.grid/
*.iml

# IDE (melos bootstrap regenerates IntelliJ run configs per checkout)
.idea/
