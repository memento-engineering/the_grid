# Dart / Flutter
.dart_tool/
build/
*.g.dart.bak
.flutter-plugins-dependencies
.packages

# DevTools extension bundles — generated by tool/build_devtools_extension.sh,
# rebuilt on demand (mirrors lenny). The config.yaml is tracked; build/ is not.
packages/*/extension/devtools/build/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# Gas City
.beads/*
!.beads/identity.toml

# the_grid live-arm worktrees (the tree engine cuts per-bead worktrees here when
# THIS checkout is the substation root: .grid/worktrees/<substation>/<bead>).
# Never tracked — they are throwaway working copies of this repo.
.grid/
*.iml
